  "keyFeatures": [
    "Appointment scheduling and management with multiple states (pending, confirmed, attended, cancelled)",
    "Doctor and specialty catalog with public endpoints",
    "Role-based access control (admin/assistant) using Supabase JWT authentication",
    "Public client registration without authentication",
    "Contact form for patient inquiries",
    "Dashboard with statistics and analytics",
    "Medical history tracking for attended appointments",
    "Appointment search and filtering capabilities"
  ],
  "publicApiSurface": [
    "POST /api/citas - Create appointment (public)",
    "GET /api/medicos/public - List active doctors (public)",
    "GET /api/especialidades - List specialties (public)",
    "POST /api/contacto - Submit contact form (public)",
    "GET /api/citas - List all appointments (admin/assistant)",
    "GET /api/citas/:id - Get appointment details (admin/assistant)",
    "GET /api/citas/buscar - Search appointments (admin/assistant)",
    "PUT /api/citas/:id/confirmar - Confirm and assign appointment (admin/assistant)",
    "PUT /api/citas/:id/atender - Mark appointment as attended (admin/assistant)",
    "PUT /api/citas/:id/cancelar - Cancel appointment (admin/assistant)",
    "DELETE /api/citas/:id - Delete appointment (admin only)",
    "GET /api/medicos - List all doctors (admin)",
    "POST /api/medicos - Create doctor (admin)",
    "PUT /api/medicos/:id - Update doctor (admin)",
    "DELETE /api/medicos/:id - Delete doctor (admin)",
    "POST /api/especialidades - Create specialty (admin)",
    "PUT /api/especialidades/:id - Update specialty (admin)",
    "DELETE /api/especialidades/:id - Delete specialty (admin)",
    "GET /api/usuarios - List users (admin)",
    "POST /api/usuarios - Create user (admin)",
    "PUT /api/usuarios/:id - Update user (admin)",
    "DELETE /api/usuarios/:id - Delete user (admin)",
    "GET /api/personas - List persons (admin/assistant)",
    "POST /api/personas - Create person (admin)",
    "PUT /api/personas/:id - Update person (admin/assistant)",
    "DELETE /api/personas/:id - Delete person (admin)",
    "GET /api/clientes - List public clients (admin/assistant)",
    "GET /api/clientes/:id - Get client details (admin/assistant)",
    "GET /api/contacto - List contact messages (public)",
    "GET /api/contacto/:id - Get contact message (public)",
    "PUT /api/contacto/:id - Update contact message (public)",
    "DELETE /api/contacto/:id - Delete contact message (public)",
    "POST /api/historial - Create medical history entry (admin/assistant)",
    "GET /api/historial/:citaId - Get medical history for appointment (admin/assistant)",
    "GET /api/dashboard/stats - Get dashboard statistics (admin/assistant)",
    "GET /api/dashboard/citas-por-estado - Get appointments by status (admin/assistant)",
    "GET /api/dashboard/citas-ultimos-7-dias - Get appointments last 7 days (admin/assistant)",
    "GET /api/dashboard/proximas-citas - Get upcoming appointments (admin/assistant)",
    "POST /api/admin-auth/login - Admin login",
    "GET /api/admin-auth/verify - Verify admin token"
  ]
}
